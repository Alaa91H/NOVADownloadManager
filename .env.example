# NOVA daemon
NOVA_DAEMON_PORT=3199
NOVA_ARIA2_RPC_PORT=6800

# Optional absolute paths if the commands are not on PATH.
# Windows examples:
# NOVA_ARIA2C=C:\tools\aria2\aria2c.exe
# NOVA_YTDLP=C:\Users\YourName\AppData\Roaming\Python\Python312\Scripts\yt-dlp.exe

# Optional front-end override. In development Vite proxies /api to this daemon URL.
VITE_NOVA_DAEMON_URL=http://127.0.0.1:3199

# Optional API URL override (falls back to VITE_NOVA_DAEMON_URL)
VITE_NOVA_API_URL=http://127.0.0.1:3199

# DISABLE_HMR=1 - Disables Vite HMR (useful for debugging)
