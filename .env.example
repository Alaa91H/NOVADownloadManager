# ---------------------------------------------------------------------------
# NOVA Download Manager - local environment overrides
# Copy to .env and adjust. All values are optional; sensible defaults apply.
# ---------------------------------------------------------------------------

# --- Daemon ---
# Port the local Rust daemon listens on (also written to the installer registry).
NOVA_DAEMON_PORT=3199

# Optional absolute paths to the engines if they are not on PATH.
# Windows examples:
# NOVA_CURL=C:\tools\curl\curl.exe
# NOVA_YTDLP=C:\Users\YourName\AppData\Roaming\Python\Python312\Scripts\yt-dlp.exe

# --- Frontend (Vite) ---
# In development Vite proxies /api to this daemon URL.
VITE_NOVA_DAEMON_URL=http://127.0.0.1:3199

# Optional API URL override (falls back to VITE_NOVA_DAEMON_URL).
VITE_NOVA_API_URL=http://127.0.0.1:3199

# Optional release-check API URL used by the desktop update flow.
# VITE_NOVA_RELEASE_API_URL=

# Set to 'true' to disable Vite HMR and file watching (useful for debugging).
# DISABLE_HMR=true

# --- Browser extension: end-to-end tests (optional) ---
# Directory of the unpacked extension build that Playwright loads.
# EXTENSION_UNPACKED_DIR=browser-extension/dist/chromium

# --- Browser extension: release automation (optional, CI/local packaging) ---
# Telegram notifications for extension releases.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# CRX signing for local extension packaging.
# CRX_PRIVATE_KEY=
# CRX_PRIVATE_KEY_PATH=
