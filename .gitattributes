# Normalize source text and keep generated/binary assets safe.
* text=auto

# Source files use LF.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Windows scripts keep CRLF for shell compatibility.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.nsi text eol=crlf

# Agent / planning files — excluded from release archives.
.agent-state.json  export-ignore
.bot-chats.json    export-ignore
.last-ci-failure   export-ignore
AGENTS.md          export-ignore
Plan.md            export-ignore
nova-dev-agent.sh  export-ignore
nova-bot.py        export-ignore
nova-bot.service   export-ignore

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.bmp binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.crx binary
*.pem binary
*.key binary
*.p12 binary
*.pkcs8 binary
*.zip binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.lib binary
*.a binary
