# NOVA factory configuration.
# Copy to /etc/nova/nova.env, fill in real values, then: chmod 600 /etc/nova/nova.env
# NEVER commit this file with real values. Secrets live only here.

# --- Telegram interface -------------------------------------------------------
# Bot token from @BotFather
NOVA_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
# Required before /register works. Get it by sending /myid to the bot.
# Multiple owners: comma or space separated, e.g. 123456789,987654321
NOVA_OWNER_IDS=
# Optional role tiers. Owners inherit all permissions; operators can restart/check; viewers are read-only.
NOVA_OPERATOR_IDS=
NOVA_VIEWER_IDS=
# Optional Telegram API credentials (my.telegram.org); leave blank if unused
NOVA_API_ID=
NOVA_API_HASH=

# /exec is disabled by default. Prefer specific bot commands and CI-backed flows.
NOVA_ENABLE_EXEC=0
# Only used when NOVA_ENABLE_EXEC=1. The command is executed without a shell.
NOVA_EXEC_ALLOWLIST=git,gh,rg,grep,ls,pwd

# --- Repository under management ---------------------------------------------
# GitHub repository the factory develops (owner/name)
NOVA_GH_REPO=Alaa91H/NOVADownloadManager
# Adopted branch policy. main is stable only; develop is continuous integration/dev.
NOVA_STABLE_BRANCH=main
NOVA_DEVELOP_BRANCH=develop
# Legacy branch support during migration from older packages that used Dev.
NOVA_LEGACY_DEVELOP_BRANCH=Dev
# Working branch for continuous development. Keep aligned with NOVA_DEVELOP_BRANCH.
NOVA_BRANCH=develop
# Branch prefixes for autonomous/human PR work.
NOVA_AGENT_BRANCH_PREFIX=agent
NOVA_FEATURE_BRANCH_PREFIX=feature
NOVA_FIX_BRANCH_PREFIX=fix
NOVA_RELEASE_BRANCH_PREFIX=release
NOVA_HOTFIX_BRANCH_PREFIX=hotfix
# Enforce PR-based work: no direct pushes to main/develop by default.
NOVA_BRANCH_POLICY_ENFORCE=1
NOVA_BRANCH_POLICY_CREATE_DEVELOP=1
NOVA_BRANCH_POLICY_ALLOW_DIRECT_MAIN=0
NOVA_BRANCH_POLICY_ALLOW_DIRECT_DEVELOP=0
NOVA_BRANCH_POLICY_APPLY_PROTECTION=0
NOVA_BRANCH_POLICY_PREFER_PR=1

# --- Execution engine ---------------------------------------------------------
# opencode model identifier
NOVA_AGENT_MODEL=opencode/big-pickle
# Optional explicit path; default is $HOME/.opencode/bin/opencode
# NOVA_OPENCODE=/home/ubuntu/.opencode/bin/opencode

# --- Runtime paths ------------------------------------------------------------
# NOVA_TARGET_USER=ubuntu
# NOVA_PROJECT_DIR=/home/ubuntu/NOVA
# NOVA_VAR_DIR=/var/lib/nova
# NOVA_LOG_DIR=/var/log/nova
# NOVA_CHATS_FILE=/var/lib/nova/bot-chats.json
# NOVA_NOTIF_FILE=/var/lib/nova/notif-prefs.json
# NOVA_BACKUP_DIR=/var/backups/nova
# NOVA_BACKUP_RETENTION_DAYS=14
# NOVA_BACKUP_MAX_COUNT=20

# --- Controller tuning --------------------------------------------------------
# NOVA_OPENCODE_TIMEOUT=2400
# NOVA_CYCLE_SLEEP=30
# NOVA_MONITOR_INTERVAL=15
# NOVA_AGENT_STALE_SEC=1800
# NOVA_WATCHDOG_AGENT_STALE_SEC=2400
# NOVA_APIHEALTH_STALL_SEC=7200

# Keep local build/test/lint/package tools disabled on the server by default.
NOVA_LOCAL_BUILD_ENABLED=0
# --- Self-update / factory lifecycle -----------------------------------------
# Enables the timer-driven update manager. Updates are validated, backed up, and
# rolled back automatically on failure. Use ff-only for sustainability.
NOVA_SELF_UPDATE_ENABLED=1
# The packaged timer checks twice daily with jitter. Keep manual /update apply for urgent fixes.
NOVA_UPDATE_STRATEGY=ff-only
NOVA_UPDATE_CHANNEL=stable
NOVA_AUTO_UPDATE_WINDOW=03:00-05:00
NOVA_ALLOW_MAJOR_UPDATE=0
NOVA_UPDATE_BACKUP_KEEP=8
# Preferred location inside the managed repo for future factory updates.
# Put this package at <repo>/ops/nova-factory to let the system update its own
# installer, systemd units, bot, controller, monitor, watchdog, and scripts.
NOVA_FACTORY_SOURCE_DIR=ops/nova-factory
# Optional: override update backup directory.
# NOVA_UPDATE_BACKUP_DIR=/var/lib/nova/backups

# --- Offsite state backup -------------------------------------------------------
# Daily mirror of /var/lib/nova state and the repo .memory to a PRIVATE GitHub
# repository (secrets in this file are never included). Empty repo = disabled.
NOVA_OFFSITE_BACKUP_ENABLED=1
# NOVA_OFFSITE_REPO=owner/nova-ops-backup


# --- Audit / observability ----------------------------------------------------
# Root-owned JSONL audit log for privileged admin actions.
# NOVA_AUDIT_LOG=/var/log/nova/audit.log
# Health snapshots are written to /var/lib/nova/health.json by doctor/monitor paths.

# --- Release / acceptance -----------------------------------------------------
# Optional output directory for locally generated factory release archives.
# NOVA_RELEASE_OUTPUT_DIR=/var/cache/nova/releases
# Number of CI/PR/release rows shown by read-only GitHub status commands.
# NOVA_CI_STATUS_LIMIT=10

# --- Autonomous orchestration -------------------------------------------------
# Global lease/inhibitor settings. Scheduled maintenance/update waits while
# critical agent/release/update work is active.
# NOVA_LEASE_DIR=/var/lib/nova/leases
# NOVA_DEFER_DIR=/var/lib/nova/deferred
# NOVA_DEFAULT_LEASE_TTL_SECONDS=7200
# NOVA_MAX_DEFERRAL_SECONDS=21600
# NOVA_DEFERRED_TIMEOUT=900
# NOVA_DEFERRED_MAX_ATTEMPTS=6
# NOVA_ORCHESTRATOR_LEASE_TTL_SECONDS=1800
# NOVA_DISPATCH_REQUEUE_DELAY_SECONDS=300
# NOVA_STATE_QUARANTINE_DIR=/var/lib/nova/quarantine

# Durable job queue for roadmap, CI repair, release, maintenance, and external
# worker dispatch. The server is the control plane; workers do the heavy work.
# NOVA_JOB_DIR=/var/lib/nova/jobs
# NOVA_JOB_STALE_SECONDS=14400
# Dispatch modes:
#   remote-or-queue  -> external worker command/webhook when configured, otherwise keep jobs queued
#   github-actions   -> use GitHub Actions as the remote worker and auto-provision workflow if missing
#   webhook          -> send jobs to NOVA_AGENT_WEBHOOK_URL
#   remote           -> call NOVA_REMOTE_AGENT_COMMAND with the job JSON
NOVA_AGENT_DISPATCH_MODE=github-actions
# Optional remote worker integration. Leave blank when using github-actions.
# NOVA_REMOTE_AGENT_COMMAND=/usr/local/bin/nova-remote-worker
# NOVA_AGENT_WEBHOOK_URL=https://worker.example.internal/nova/jobs
NOVA_ALLOW_LOCAL_AGENT_DISPATCH=0

# --- GitHub Actions remote worker --------------------------------------------
# Lets the weak server create/maintain .github/workflows/nova-worker.yml and dispatch
# workflow_dispatch jobs. For direct workflow commits, the gh token/PAT must be able
# to write workflow files. Keep PR mode if you want a human merge gate.
NOVA_GITHUB_REPO=Alaa91H/NOVADownloadManager
NOVA_GITHUB_WORKER_WORKFLOW=nova-worker.yml
NOVA_GITHUB_WORKER_AUTO_PROVISION=1
# pr = create/update a PR and wait for merge; commit = commit workflow directly to base branch.
NOVA_GITHUB_WORKER_PROVISION_MODE=pr
NOVA_GITHUB_WORKER_BASE_BRANCH=develop
NOVA_GITHUB_WORKER_BRANCH=nova/bootstrap-github-worker
NOVA_GITHUB_WORKER_CREATE_PR=1
NOVA_GITHUB_WORKER_FORCE_UPDATE=0
# NOVA_GITHUB_WORKER_NODE_VERSION=22

# Release train channels and emergency recovery. Reboot remains disabled unless
# explicitly enabled and protected by cooldown/boot-loop guards.
# NOVA_RELEASE_TRAIN_STATE=/var/lib/nova/release-train.json
NOVA_EMERGENCY_REBOOT_ENABLED=0
NOVA_EMERGENCY_FAILURE_THRESHOLD=4
NOVA_EMERGENCY_STALE_MINUTES=30
NOVA_EMERGENCY_REBOOT_COOLDOWN_HOURS=12
