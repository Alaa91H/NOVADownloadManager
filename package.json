{
  "name": "nova",
  "private": true,
  "version": "0.1.0",
  "description": "NOVA download manager UI powered by local direct and media download engines.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.6.0",
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:prepare": "node scripts/build-tauri-assets.mjs",
    "tauri:build": "node scripts/apply-version.mjs --optional && tauri build",
    "version:apply": "node scripts/apply-version.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node scripts/clean.mjs",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:catalog": "tsx scripts/i18n-catalog.mjs",
    "i18n:dicts": "tsx scripts/i18n-dicts.mjs",
    "i18n:update": "tsx scripts/update-translations.mjs",
    "i18n:sync": "tsx scripts/sync-i18n-index.mjs",
    "i18n:validate": "tsx scripts/validate-i18n.mjs",
    "i18n:validate-primary": "tsx scripts/validate-primary-i18n.mjs",
    "extension:install": "pnpm install --frozen-lockfile",
    "extension:build": "pnpm --filter nova-browser-extension build",
    "extension:package": "pnpm --filter nova-browser-extension build:zip",
    "fetch-engines": "node scripts/build-native-curl.mjs && node scripts/fetch-engines.mjs",
    "bundle": "node scripts/build-bundle.mjs",
    "release": "node scripts/build-native-curl.mjs && node scripts/fetch-engines.mjs && node scripts/build-bundle.mjs",
    "native-curl:build": "node scripts/build-native-curl.mjs",
    "native-curl:env": "node scripts/print-native-curl-env.mjs",
    "native-curl:verify": "node scripts/verify-native-curl.mjs",
    "audit:final": "node scripts/final-audit.mjs && node scripts/verify-capability-gating.mjs && node scripts/installer-lifecycle-audit.mjs && pnpm --filter nova-browser-extension verify:nova-sync && pnpm --filter nova-browser-extension audit:release",
    "audit:installer": "node scripts/installer-lifecycle-audit.mjs",
    "verify:capabilities": "node scripts/verify-capability-gating.mjs"
  },
  "dependencies": {
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "lucide-react": "^1.23.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
