{
    "name": "nova",
    "private": true,
    "version": "0.1.0",
    "description": "NOVA download manager UI powered by local direct and media download engines.",
    "type": "module",
    "scripts": {
        "dev": "vite --port=3000 --host=0.0.0.0",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:prepare": "node scripts/build-tauri-assets.mjs",
        "tauri:build": "tauri build",
        "version:apply": "node scripts/apply-version.mjs",
        "build": "vite build",
        "preview": "vite preview",
        "clean": "node scripts/clean.mjs",
        "lint": "tsc --noEmit",
        "lint:eslint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "i18n:update": "tsx scripts/update-translations.mjs",
        "i18n:sync": "tsx scripts/sync-i18n-index.mjs",
        "i18n:validate": "tsx scripts/validate-i18n.mjs",
        "i18n:validate-primary": "tsx scripts/validate-primary-i18n.mjs",
        "extension:install": "pnpm --dir browser-extension install --frozen-lockfile",
        "extension:build": "pnpm --dir browser-extension build",
        "extension:package": "pnpm --dir browser-extension build:zip",
        "fetch-engines": "node scripts/fetch-engines.mjs",
        "bundle": "node scripts/build-bundle.mjs",
        "release": "node scripts/fetch-engines.mjs && node scripts/build-bundle.mjs"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.1.14",
        "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
        "@tauri-apps/plugin-dialog": "^2",
        "@vitejs/plugin-react": "^5.0.4",
        "dotenv": "^17.2.3",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "react": "^19.0.1",
        "react-dom": "^19.0.1",
        "vite": "^6.2.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tauri-apps/api": "^2.11.1",
        "@tauri-apps/cli": "^2.11.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.14.0",
        "@vitalets/google-translate-api": "^9.2.1",
        "@vitest/coverage-v8": "^4.1.9",
        "autoprefixer": "^10.4.21",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.4",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "typescript-eslint": "^8.62.1",
        "vite": "^6.2.3",
        "vitest": "^4.1.9"
    }
}
