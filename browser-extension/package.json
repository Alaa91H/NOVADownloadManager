{
  "name": "nova-browser-extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "wxt -b chrome --mv3",
    "clean": "tsx tools/clean.ts",
    "clean:artifacts": "tsx tools/clean.ts",
    "wxt:build:chrome": "cross-env WXT_TARGET=chrome wxt build -b chrome --mv3",
    "wxt:build:edge": "cross-env WXT_TARGET=edge wxt build -b chrome --mv3",
    "wxt:build:firefox": "cross-env WXT_TARGET=firefox wxt build -b firefox --mv3",
    "wxt:build:store": "cross-env WXT_STORE=1 WXT_TARGET=store wxt build -b chrome --mv3",
    "build": "node scripts/run-python.js build.py --clean",
    "build:zip": "node scripts/run-python.js build.py --clean --zip",
    "build:dist": "node scripts/run-python.js build.py --clean --zip",
    "build:chrome": "pnpm wxt:build:chrome",
    "build:edge": "pnpm wxt:build:edge",
    "build:firefox": "pnpm wxt:build:firefox",
    "build:store": "pnpm wxt:build:store",
    "build:all": "pnpm build:chrome && pnpm build:firefox && pnpm build:store",
    "package:chrome": "cross-env WXT_TARGET=chrome wxt build -b chrome --mv3 && wxt zip -b chrome",
    "package:edge": "node scripts/run-python.js tools/create-edge-package.py",
    "package:firefox": "cross-env WXT_TARGET=firefox wxt build -b firefox --mv3 && wxt zip -b firefox",
    "package:all": "pnpm package:chrome && pnpm package:edge && pnpm package:firefox && pnpm prune:package-outputs",
    "prune:package-outputs": "tsx tools/prune-package-outputs.ts",
    "test": "wxt prepare && vitest run",
    "test:js": "wxt prepare && vitest run",
    "test:unit": "wxt prepare && vitest run src/tests/unit",
    "test:contract": "wxt prepare && vitest run src/tests/contract",
    "test:integration": "wxt prepare && vitest run src/tests/integration",
    "test:py": "python -m pytest tests/ -v --ignore=tests/browser",
    "test:e2e": "playwright test",
    "docs:check": "tsx tools/docs-readiness-check.ts",
    "guard:e2e": "tsx tools/e2e-readiness-check.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "wxt prepare && tsc --noEmit",
    "check:mv3": "pnpm validate:manifests",
    "validate:manifests": "tsx tools/validate-manifests.ts",
    "validate:package": "tsx tools/package-validator.ts",
    "guard:production": "tsx tools/production-guard.ts",
    "verify:store": "pnpm build:store && tsx tools/store-readiness-check.ts",
    "verify:desktop-contract": "tsx tools/desktop-contract-check.ts",
    "verify:highest": "pnpm deps:policy && pnpm guard:e2e && pnpm guard:transport && pnpm guard:storage && pnpm guard:runtime && pnpm guard:aggressive-permissions && pnpm actions:policy && pnpm manifest:policy && pnpm guard:architecture && pnpm validate:package && pnpm package:hygiene && pnpm guard:production && pnpm verify:store",
    "release:artifacts": "tsx tools/copy-artifacts.ts",
    "release:metadata": "tsx tools/release-metadata.ts && pnpm release:sbom",
    "release:check": "pnpm release:metadata && pnpm validate:package && pnpm guard:production",
    "release:checks": "tsx tools/release-checks.ts --package-only",
    "ci": "pnpm verify:offline && pnpm typecheck && pnpm lint && pnpm test && pnpm test:py && pnpm build:zip && pnpm validate:manifests && pnpm test:e2e && pnpm verify:release:reuse-build",
    "ci:quick": "pnpm typecheck && pnpm lint && pnpm test",
    "ci:package": "pnpm build:zip && pnpm verify:highest",
    "fake-nova": "tsx fake-nova-daemon/server.ts",
    "deps:policy": "tsx tools/dependency-policy-check.ts",
    "guard:architecture": "tsx tools/architecture-guard.ts",
    "actions:policy": "tsx tools/github-actions-policy-check.ts",
    "manifest:policy": "tsx tools/manifest-source-policy-check.ts",
    "release:sbom": "tsx tools/create-sbom.ts",
    "contracts:generate": "tsx tools/generate-contract-schemas.ts",
    "package:hygiene": "python tools/package_hygiene_check.py",
    "guard:transport": "tsx tools/transport-budget-policy-check.ts",
    "guard:storage": "tsx tools/storage-budget-policy-check.ts",
    "guard:runtime": "tsx tools/runtime-boundary-policy-check.ts",
    "guard:aggressive-permissions": "tsx tools/aggressive-permission-policy-check.ts",
    "preflight:production": "node tools/preflight.mjs",
    "verify:production": "pnpm verify:offline && pnpm verify:highest && pnpm signoff:production -- --strict",
    "audit:offline": "node tools/offline-production-audit.mjs",
    "verify:offline": "pnpm preflight:production && pnpm audit:offline && pnpm audit:release && pnpm verify:nova-sync",
    "audit:release": "node tools/release-submission-audit.mjs",
    "signoff:production": "node tools/final-production-signoff.mjs",
    "verify:release:reuse-build": "pnpm deps:policy && pnpm guard:e2e && pnpm guard:transport && pnpm guard:storage && pnpm guard:runtime && pnpm guard:aggressive-permissions && pnpm actions:policy && pnpm manifest:policy && pnpm guard:architecture && pnpm validate:package && pnpm package:hygiene && pnpm guard:production && tsx tools/store-readiness-check.ts",
    "release:notes": "node tools/prepare-release-notes.mjs",
    "verify:nova-sync": "node tools/nova-extension-feature-parity-check.mjs"
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.2.2",
    "dexie": "^4.4.4",
    "m3u8-parser": "^7.2.0",
    "mpd-parser": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^7.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  },
  "engines": {
    "node": ">=24 <27",
    "pnpm": ">=11 <12"
  },
  "description": "NOVA Browser Extension companion"
}
