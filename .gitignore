# NOVA Download Manager — repository-wide ignore rules
#
# Philosophy: ignore build outputs, generated artifacts, runtime state, caches,
# environment secrets, OS/editor noise, and release binaries. Keep source,
# contracts, documentation, manifests, and automation scripts committed.

# ──────────────────────────────────────────────────────
# Dependencies & package-manager caches
# ──────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.npm/
.yarn/
.pnp.*
corepack-cache/

# Lockfile policy: one root pnpm lockfile is canonical.
**/pnpm-lock.yaml
!pnpm-lock.yaml
package-lock.json
yarn.lock

# Package-manager diagnostics
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────────────
# Environment files & local secrets
# ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pkcs8
*.crt
*.cer
*.csr

# The bundled Mozilla CA certificate bundle is a public, non-sensitive build
# resource used by the libcurl engine for HTTPS verification on Windows.
!src-tauri/cacert.pem

# ──────────────────────────────────────────────────────
# Build outputs & generated web assets
# ──────────────────────────────────────────────────────
dist/
build/
out/
coverage/
coverage-final.json
.vite/
.cache/
.temp/
tmp/
temp/
*.tsbuildinfo

# ──────────────────────────────────────────────────────
# Desktop runtime & local daemon artifacts
# ──────────────────────────────────────────────────────
.nova-runtime/
.nova-port
start-daemon.bat
daemon*.log
daemon*.err
bundle/
release/
package/

# ──────────────────────────────────────────────────────
# Download engines & generated native dependencies
# ──────────────────────────────────────────────────────
bin/
vendor/native/

# ──────────────────────────────────────────────────────
# Tauri / Rust outputs
# ──────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/
src-tauri/resources/*
!src-tauri/resources/.gitkeep
**/*.rs.bk

# ──────────────────────────────────────────────────────
# Platform icons not needed for Windows builds
# ──────────────────────────────────────────────────────
src-tauri/icons/android/
src-tauri/icons/ios/
src-tauri/icons/Square*.png
src-tauri/icons/StoreLogo.png

# ──────────────────────────────────────────────────────
# Browser extension generated outputs
# ──────────────────────────────────────────────────────
browser-extension/node_modules/
browser-extension/dist/
browser-extension/.output/
browser-extension/.wxt/
browser-extension/coverage/
browser-extension/playwright-report/
browser-extension/test-results/
browser-extension/.pytest_cache/
browser-extension/.nyc_output/
browser-extension/*.crx
browser-extension/*.crx.pem
browser-extension/*.nex
browser-extension/*.zip
browser-extension/ts-errors.txt

# ──────────────────────────────────────────────────────
# Test & report output
# ──────────────────────────────────────────────────────
playwright-report/
test-results/
pytest_cache/
.pytest_cache/
htmlcov/
.junit/
reports/
*.lcov

# ──────────────────────────────────────────────────────
# Python caches & virtual environments
# ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# ──────────────────────────────────────────────────────
# OS & editor noise
# ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ──────────────────────────────────────────────────────
# Logs & temporary files
# ──────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.pid
*.seed
*.pid.lock

# ──────────────────────────────────────────────────────
# Archives & installers generated by release jobs
# ──────────────────────────────────────────────────────
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.exe
*.msi
*.dmg
*.pkg
*.AppImage

# Keep committed source archives only if explicitly placed under docs/release fixtures.
!docs/**/*.zip

# ──────────────────────────────────────────────────────
# Development planning artifacts (not shipped)
# ──────────────────────────────────────────────────────
Plan.md
metadata.json
