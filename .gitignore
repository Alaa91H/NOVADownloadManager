# NOVA Download Manager — repository-wide ignore rules
# Keep source, contracts, docs, manifests, and release scripts committed.

# Dependencies and package-manager caches
node_modules/
.pnpm-store/
.npm/
.yarn/
.pnp.*
corepack-cache/


# Lockfile policy: the repository uses one root pnpm lockfile.
**/pnpm-lock.yaml
!pnpm-lock.yaml
package-lock.json
yarn.lock

# Package manager diagnostics
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files and local secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pkcs8
*.crt
*.cer
*.csr

# Build outputs and generated web assets
dist/
build/
out/
coverage/
coverage-final.json
.vite/
.cache/
.temp/
tmp/
temp/
*.tsbuildinfo

# Desktop runtime and local daemon artifacts
.nova-runtime/
.nova-port
start-daemon.bat
daemon*.log
daemon*.err
bundle/
release/
package/

# Download engines and generated native dependencies
bin/
vendor/native/

# Tauri/Rust outputs
src-tauri/target/
src-tauri/gen/
src-tauri/resources/
**/*.rs.bk

# Browser extension generated outputs
browser-extension/node_modules/
browser-extension/dist/
browser-extension/.output/
browser-extension/.wxt/
browser-extension/coverage/
browser-extension/playwright-report/
browser-extension/test-results/
browser-extension/.pytest_cache/
browser-extension/.nyc_output/
browser-extension/*.crx
browser-extension/*.crx.pem
browser-extension/*.nex
browser-extension/*.zip
browser-extension/ts-errors.txt

# Test and report output
playwright-report/
test-results/
pytest_cache/
.pytest_cache/
htmlcov/
.junit/
reports/
*.lcov

# Python caches and virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# OS and editor noise
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.pid
*.seed
*.pid.lock

# Archives and installers generated by release jobs
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.exe
*.msi
*.dmg
*.pkg
*.AppImage

# Keep committed source archives only if explicitly placed under docs/release fixtures later.
!docs/**/*.zip

# Agent files — server-only, not tracked in repo
nova-dev-agent.sh
nova-bot.py
CONSTITUTION.md
scripts/agent/
